{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "extends": ["../../biome.json"],
  "vcs": {
    "useIgnoreFile": true,
    "root": "../.."
  },
  "files": {
    "includes": ["**", "!!**/src/routeTree.gen.ts"]
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noShorthandPropertyOverrides": "off"
      }
    }
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": true
    }
  }
}
